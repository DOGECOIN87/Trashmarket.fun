{
  "name": "trash-market",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "deploy:github": "gh-pages -d dist --dotfiles",
    "deploy:cloudflare": "wrangler pages deploy dist",
    "security:audit": "npm audit --production",
    "security:check": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "lavamoat:check": "lavamoat --config lavamoat.config.json",
    "lavamoat:policy": "lavamoat --writeAutoPolicy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.30.1",
    "@dimforge/rapier3d-compat": "^0.19.3",
    "@gorid/spl-name-service": "^1.0.5",
    "@privy-io/react-auth": "^3.17.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/wallet-adapter-backpack": "^0.1.14",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@solana/wallet-adapter-react-ui": "^0.9.39",
    "@solana/web3.js": "^1.98.4",
    "@types/bs58": "^5.0.0",
    "bn.js": "^5.2.3",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.1",
    "firebase-tools": "^15.6.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.10.0",
    "three": "^0.182.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/bn.js": "^5.2.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.11",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "gh-pages": "^6.3.0",
    "lavamoat": "^10.1.1",
    "mocha": "^11.7.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "terser": "^5.46.0",
    "ts-mocha": "^11.1.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vite-plugin-node-polyfills": "0.21.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.66.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "security": {
    "audit": true,
    "lavamoat": true
  }
}
