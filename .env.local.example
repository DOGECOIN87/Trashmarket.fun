# JUNKPUSHER Game Configuration
# This file contains the necessary environment variables for the JUNKPUSHER game

# Solana Program ID for JUNKPUSHER game
# Set this to the deployed program ID on Gorbagana
VITE_SOLANA_PROGRAM_ID=5gJkp3DsVTtBP6k7WtbiNBjQhAESgGrgu6AJfypMCAwe

# DEBRIS Token Configuration
# Token Mint: DebrikgCUTkxMGSxnBoVuwqpW4zivMrUfUP6kUeNUMwy
# Decimals: 9
# Network: Gorbagana

# Game Treasury Wallet (public key of the wallet holding DEBRIS for payouts)
VITE_GAME_TREASURY_WALLET=8iKCvwz3tyUp4hzxcyLYtPQghiwiEhiLDd38MEQBF6kR

# RPC Endpoint (optional - defaults to Gorbagana RPC)
VITE_GORBAGANA_RPC=https://rpc.trashscan.io

# Game Configuration (optional - these are defaults)
# VITE_GAME_INITIAL_BALANCE=100
# VITE_GAME_BUMP_COST=50
# VITE_GAME_DROP_COST=1

# Security Settings
# Enable strict token validation
VITE_ENABLE_TOKEN_VALIDATION=true

# Enable withdrawal protection (only allow withdrawal of verified winnings)
VITE_ENABLE_WITHDRAWAL_PROTECTION=true

# Maximum deposit amount (in base units, 9 decimals)
VITE_MAX_DEPOSIT_AMOUNT=1000000000000000

# Maximum game score
VITE_MAX_GAME_SCORE=999999999
