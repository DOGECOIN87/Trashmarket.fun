rules_version = '2';

// Trashmarket.fun Firestore Security Rules
//
// Deploy with: firebase deploy --only firestore:rules,firestore:indexes

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Collection Submissions ──────────────────────────────────────────
    match /submissions/{submissionId} {

      // Public can read approved submissions.
      // Submitters can read their own (any status).
      // Admins can read everything.
      allow read: if resource.data.status == 'approved'
                  || isSubmitter()
                  || isAdmin();

      // Any user (including anonymous Firebase auth) can create a submission.
      // Status must start as 'pending' and submissionCount <= 3.
      allow create: if request.auth != null
                    && request.resource.data.status == 'pending'
                    && request.resource.data.submittedBy is string
                    && request.resource.data.name is string
                    && request.resource.data.submissionCount <= 3;

      // Only admin can approve/reject (update status)
      allow update: if isAdmin();

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ─── Helper functions ────────────────────────────────────────────────

    function isSubmitter() {
      return request.auth != null
             && resource.data.submittedBy == request.auth.token.wallet;
    }

    // Admin identified by their Firebase Twitter Auth UID
    function isAdmin() {
      return request.auth != null
             && request.auth.uid == 'CxRiZEpdmahmAFId6aLEYMHt7uJ3';
    }

    // ─── Site config (admin dashboard controls) ─────────────────────────
    match /site_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Gorbagio NFT Marketplace Listings ──────────────────────────────
    match /gorbagio_listings/{mintAddress} {
      allow read: if true;

      allow create: if request.auth != null
                    && request.resource.data.seller is string
                    && request.resource.data.priceSol > 0
                    && request.resource.data.active == true;

      allow update: if request.auth != null
                    && resource.data.seller == request.auth.token.wallet;

      allow delete: if request.auth != null
                    && resource.data.seller == request.auth.token.wallet;
    }

    // ─── Airdrop Registrations ──────────────────────────────────────────
    match /airdrop_registrations/{twitterUid} {
      allow read: if request.auth != null
                  && request.auth.uid == twitterUid;

      allow create: if request.auth != null
                    && request.auth.uid == twitterUid
                    && request.resource.data.twitterUid == twitterUid
                    && request.resource.data.walletAddress is string
                    && request.resource.data.walletAddress.size() >= 32
                    && request.resource.data.walletAddress.size() <= 44;

      allow update, delete: if false;
    }

    // ─── Deny everything else ────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
